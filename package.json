{
  "name": "treemakerweb",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser port of TreeMaker 5 (origami crease-pattern design). See DESIGN.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "oracle": "bash tools/oracle/build_and_run.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.20.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
